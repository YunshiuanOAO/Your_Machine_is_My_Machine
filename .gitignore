# Your_Machine_is_My_Machine gitignore

## OS / filesystem noise
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.TemporaryItems
.fseventsd
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
ehthumbs.db
Icon
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

## Editor / IDE local state
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp
*.orig

## Python caches and build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.eggs-info/
pip-wheel-metadata/
wheels/
share/python-wheels/
MANIFEST
*.manifest
*.spec

## Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.nox/
.tox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
cover/
*.cover
*.py,cover
.dmypy.json
dmypy.json
cython_debug/
.ipynb_checkpoints/

## Python virtual environments and package managers
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/
.pdm.toml
poetry.toml

## uv local cache
.uv-cache/

## Node / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/
.yarn/

## Environment files, secrets, and credentials
.env
.env.*
!.env.example
*.local
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts
known_hosts.*

## VPN and pentest local access state
*.ovpn
.pentestagent-vpn.env
vpn/*
!vpn/.gitkeep

## Pentest run artifacts
reports/*
!reports/.gitkeep
scan/
commands/
agent_workers/
agent_reports/
codex_decision/
success_skill/
exploit*/
http_*/
sessions/
shells/
loot/

## Local agent / Codex state
.agents/
.codex/
.codex-sessions/
.codex-cache/

## Local databases and generated data
*.sqlite
*.sqlite3
*.sqlite3-*
*.db
*.db-journal
*.db-shm
*.db-wal

# Keep the checked-in Chroma knowledge base, but ignore transient sqlite sidecars.
!my_knowledge_base/chroma.sqlite3
my_knowledge_base/*.sqlite3-*

## Logs and runtime dumps
*.log
logs/
*.pid
*.seed
*.pid.lock
core
core.*
*.stackdump
*.dmp

## Temporary generated media in the repo root
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.gif

# Keep documentation assets tracked.
!docs/assets/
!docs/assets/*.png
!docs/assets/*.jpg
!docs/assets/*.jpeg
!docs/assets/*.webp
!docs/assets/*.gif
!docs/assets/*.svg

## Docker / compose local overrides
docker-compose.override.yml
.docker/

## Misc local outputs
tmp/
temp/
.cache/
site/
docs/_build/
