ANTHROPIC_API_KEY=
PENTEST_ENV=dev
PENTEST_MODEL_NAME=claude-sonnet-4-6
PENTEST_KNOWLEDGE_BASE_PATH=my_knowledge_base
PENTEST_COLLECTION_NAME=hacktricks_kb
PENTEST_REPORT_DIR=reports
PENTEST_MAX_RETRIES=2
PENTEST_RUN_TIMEOUT_SECONDS=3600
PENTEST_COMMAND_TIMEOUT_SECONDS=300
PENTEST_SCAN_TIMEOUT_SECONDS=300
PENTEST_WEB_SCAN_TIMEOUT_SECONDS=180
PENTEST_WEB_WORDLIST=wordlists/medium.txt
PENTEST_RAG_TOP_K=3
PENTEST_RAG_MAX_SNIPPETS=6
PENTEST_RAG_SNIPPET_BUDGET_CHARS=2000
PENTEST_AUTO_APPROVE=false
PENTEST_ALLOW_INTERACTIVE=false
PENTEST_EXPLOIT_DISPATCH=sequential
