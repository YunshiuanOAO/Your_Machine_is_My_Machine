# Anthropic API key. Required for LLM-backed decisions unless running with --no-llm.
ANTHROPIC_API_KEY=

# Optional LangSmith Cloud tracing. Keep false/off unless you want traces uploaded.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pentestagent-dev
# Set only for non-default LangSmith regions, for example https://eu.api.smith.langchain.com.
LANGSMITH_ENDPOINT=

# Config environment name. Loads config.yaml, then config-<env>.yaml, then these env overrides.
PENTEST_ENV=dev

# Claude model name. Override here if your provider/account requires a fully versioned model ID.
PENTEST_MODEL_NAME=claude-sonnet-4-6

# Local Chroma knowledge base directory and collection name.
PENTEST_KNOWLEDGE_BASE_PATH=my_knowledge_base
PENTEST_COLLECTION_NAME=hacktricks_kb

# Base directory for generated reports/<run_id>/ artifacts.
PENTEST_REPORT_DIR=reports

# Global retry budget for exploit-task retry cycles.
PENTEST_MAX_RETRIES=2

# Whole-run wall-clock timeout. Separate from per-command and per-scan timeouts.
PENTEST_RUN_TIMEOUT_SECONDS=3600

# Per-command timeout used by services/executor.py.
PENTEST_COMMAND_TIMEOUT_SECONDS=300

# Scanner timeouts. scan = RustScan/Nmap, web_scan = Dirsearch/WhatWeb.
PENTEST_SCAN_TIMEOUT_SECONDS=300
PENTEST_WEB_SCAN_TIMEOUT_SECONDS=180

# Wordlist used by Dirsearch. Relative paths resolve from the project root.
PENTEST_WEB_WORDLIST=wordlists/medium.txt

# RAG context budget. top_k is per query; max_snippets and snippet_budget_chars cap prompt growth.
PENTEST_RAG_TOP_K=3
PENTEST_RAG_MAX_SNIPPETS=6
PENTEST_RAG_SNIPPET_BUDGET_CHARS=2000

# If true, skip the human approval prompt. Keep false for first live HTB/Kali runs.
PENTEST_AUTO_APPROVE=false

# Interactive commands are disabled in v1 until a TTY/session manager exists.
PENTEST_ALLOW_INTERACTIVE=false

# v1 supports only sequential exploit dispatch: one ExploitTask at a time.
# "parallel" is reserved for v2 fan-out/fan-in and is not implemented yet.
PENTEST_EXPLOIT_DISPATCH=sequential
